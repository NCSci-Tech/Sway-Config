{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/workspaces"],
  "modules-center": ["custom/network", "cpu", "memory", "battery"],
  "modules-right": ["pulseaudio", "clock"],

  "custom/network": {
    "exec": "connmanctl services | awk '/\\/\\/.*online/ {print $3}' | head -n1",
    "interval": 5,
    "format": "Net: {}",
    "on-click": "gnome-terminal -e 'connmanctl services'"
  },

  "cpu": {
    "format": "CPU: {}%",
    "exec": "grep 'cpu ' /proc/stat | awk 'NR==1 {usage=($2+$4)*100/($2+$4+$5); printf \"%0.0f\", usage}'",
    "interval": 5
  },

  "memory": {
    "format": "RAM: {}%",
    "exec": "free | awk '/Mem:/ {printf \"%0.0f\", $3/$2*100}'",
    "interval": 5
  },

  "battery": {
    "format": "{capacity}% {status}",
    "exec": "cat /sys/class/power_supply/BAT*/capacity",
    "interval": 30
  },

  "pulseaudio": {
    "format": "Vol: {}",
    "exec": "pactl get-sink-volume @DEFAULT_SINK@ | awk '{print $5}' | head -n1",
    "interval": 2
  },

  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  }
}
