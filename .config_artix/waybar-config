{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/workspaces"],
  "modules-center": ["network", "cpu", "memory", "battery"],
  "modules-right": ["pulseaudio", "clock"],

  "sway/workspaces": {
    "disable-scroll": true,
    "format": "{name}"
  },

  "network": {
    "format-wifi": "  {essid}",
    "format-ethernet": "  {ifname}",
    "format-disconnected": "⚠ disconnected",
    "interval": 5
  },

  "cpu": {
    "format": " {usage}%",
    "interval": 5
  },

  "memory": {
    "format": " {percentage}%",
    "interval": 5
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": ["", "", "", "", ""],
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 30
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " muted",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "clock": {
    "format": " {:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  }
}
